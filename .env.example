# Copy to .env and customize. .env is gitignored.

# --- Database (libSQL / Turso) ---
# Local file (dev) : "file:/data/reader/reader.db" (volume Docker)
#                    "file:./data/reader.db" (hors Docker)
# Turso remote     : "libsql://<db>-<org>.turso.io"  + DATABASE_AUTH_TOKEN
DATABASE_URL=file:/data/reader/reader.db
DATABASE_AUTH_TOKEN=

# --- Auth.js ---
# Secret pour signer les sessions. Génère avec : openssl rand -base64 32
AUTH_SECRET=

# URL publique du reader (utilisée par Auth.js pour les magic-links)
AUTH_URL=http://localhost:3002

# Trust the AUTH_URL host header even when behind a proxy (dev)
AUTH_TRUST_HOST=true

# --- Resend (magic-link) ---
RESEND_API_KEY=
AUTH_EMAIL_FROM=noreply@example.com

# --- Ingest (extractor → reader) ---
# Secret partagé Bearer entre l'extractor et le reader pour /api/ingest/*.
# Génère avec : openssl rand -base64 32 (doit faire ≥ 32 caractères).
INGEST_SECRET=

# --- Admin ---
# Email qui a accès aux endpoints /api/admin/*. À matcher exactement avec
# l'email d'invitation que tu te poses à toi-même.
ADMIN_EMAIL=admin@example.com
