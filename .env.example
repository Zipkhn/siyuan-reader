# Copy to .env and customize. .env is gitignored.

# --- Database ---
# Chemin du fichier SQLite. En Docker dev : volume nommé monté sur /data/reader.
DATABASE_URL=/data/reader/reader.db

# --- Auth.js ---
# Secret pour signer les sessions. Génère avec : openssl rand -base64 32
AUTH_SECRET=

# URL publique du reader (utilisée par Auth.js pour les magic-links)
AUTH_URL=http://localhost:3002

# Trust the AUTH_URL host header even when behind a proxy (dev)
AUTH_TRUST_HOST=true

# --- Resend (magic-link) ---
RESEND_API_KEY=
AUTH_EMAIL_FROM=noreply@example.com

# --- Snapshots ---
# Racine du volume snapshots produit par l'extracteur (read-only).
SNAPSHOTS_DIR=/data/snapshots

# --- Admin ---
# Email qui a accès aux endpoints /api/admin/*. À matcher exactement avec
# l'email d'invitation que tu te poses à toi-même.
ADMIN_EMAIL=admin@example.com
